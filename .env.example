# .env.example
# Copy this file to .env and fill in your actual values

# Server Configuration
NODE_ENV=development
PORT=3000
HOST=localhost

# Database Configuration (if using actual database)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cicada_db
DB_USER=cicada_user
DB_PASSWORD=your_password_here

# Email Configuration (for sending contact form emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@cicada.com

# API Configuration
API_KEY=your_api_key_here
API_SECRET=your_api_secret_here
JWT_SECRET=your_jwt_secret_here

# Third Party Services
STRIPE_KEY=your_stripe_key_here
STRIPE_SECRET=your_stripe_secret_here

# Analytics
GOOGLE_ANALYTICS_ID=UA-XXXXXXXXX-X

# AWS/Cloud Configuration
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret

# Session Configuration
SESSION_SECRET=your_session_secret_here
SESSION_TIMEOUT=3600000

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,https://cicada-org.example.com

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log

# Email Notifications
SEND_EMAIL_ON_CONTACT=true
ADMIN_EMAIL=admin@cicada.com

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# Security
HELMET_ENABLED=true
HELMET_CSP_ENABLED=false
